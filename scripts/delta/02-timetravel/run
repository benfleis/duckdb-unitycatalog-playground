#!/usr/bin/env bash
set -euo pipefail

DUCKDB_BIN="${DUCKDB_BIN:-duckdb}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
DATA_PATH="${DATA_PATH:-$REPO_ROOT/data}"
TABLE_PATH="$DATA_PATH/blog/insert_example"

ATTACH_LATEST="ATTACH '$TABLE_PATH' AS my_table (TYPE delta);"
ATTACH_V1="ATTACH '$TABLE_PATH' AS my_table_v1 (TYPE delta, VERSION 1);"
ATTACH_PINNED="ATTACH '$TABLE_PATH' AS my_table_pinned (TYPE delta, PIN_SNAPSHOT);"

dshow() { "$DUCKDB_BIN" -c "$ATTACH_LATEST $1"; }
dval() { "$DUCKDB_BIN" -csv -noheader -c "$ATTACH_LATEST $1"; }
dshow_v1() { "$DUCKDB_BIN" -c "$ATTACH_V1 $1"; }
dval_v1() { "$DUCKDB_BIN" -csv -noheader -c "$ATTACH_V1 $1"; }
dshow_pinned() { "$DUCKDB_BIN" -c "$ATTACH_PINNED $1"; }
dval_pinned() { "$DUCKDB_BIN" -csv -noheader -c "$ATTACH_PINNED $1"; }

assert_eq() {
    local label="$1" actual="$2" expected="$3"
    if [[ "$actual" != "$expected" ]]; then
        echo "  ❌ $label: expected '$expected', got '$actual'" >&2
        exit 1
    fi
    echo "  ✅ $label: '$actual'"
}

echo "--- Plain ATTACH: latest (v2, all rows) ---"
dshow "FROM my_table ORDER BY code;"
assert_eq "row count at latest" "$(dval 'SELECT count() FROM my_table;')" "6"

echo "--- AT (VERSION => 1): post first insert, pre bulk copy ---"
dshow "FROM my_table AT (VERSION => 1) ORDER BY code;"
assert_eq "row count at v1" "$(dval 'SELECT count() FROM my_table AT (VERSION => 1);')" "3"

echo "--- AT (VERSION => 0): initial table, Question 1 only ---"
dshow "FROM my_table AT (VERSION => 0) ORDER BY code;"
assert_eq "row count at v0" "$(dval 'SELECT count() FROM my_table AT (VERSION => 0);')" "1"

echo "--- ATTACH (VERSION 1): always v1 regardless of future writes ---"
dshow_v1 "FROM my_table_v1 ORDER BY code;"
assert_eq "row count pinned v1" "$(dval_v1 'SELECT count() FROM my_table_v1;')" "3"

echo "--- ATTACH (PIN_SNAPSHOT): locked to latest at attach time ---"
dshow_pinned "FROM my_table_pinned ORDER BY code;"
assert_eq "row count pin_snapshot" "$(dval_pinned 'SELECT count() FROM my_table_pinned;')" "6"
